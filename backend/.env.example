# ── Server ────────────────────────────────────────────
PORT=3000

# ── Database (MongoDB Atlas) ────────────────────────
# Get from: atlas.mongodb.com → Connect → Drivers → copy the URI
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/felicity?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────
# Use any long random string for JWT_SECRET (e.g. openssl rand -hex 32)
JWT_SECRET=your_long_random_secret_here

# ── Admin seed account ────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ── SMTP (Gmail App Password recommended) ────────────
# Generate at: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=youremail@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_DISABLE=false

# ── CORS ──────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── hCaptcha (optional) ─────────────────────────
HCAPTCHA_SECRET_KEY=

# ── Environment ──────────────────────────────────
# Set to 'production' on Render for correct cookie settings
NODE_ENV=development
