!.env.example

# ── Build outputs ─────────────────────────────────────────────
frontend/dist/
frontend/build/
backend/dist/

# ── Logs ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── OS / Editor junk ──────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json

# ── Misc ──────────────────────────────────────────────────────
*.tsbuildinfo
.eslintcache
.cache/
